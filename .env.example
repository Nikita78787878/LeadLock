# Telegram Bot Token
BOT_TOKEN=your_telegram_bot_token_here_change_me

# Bot version (LITE, PRO, AI)
VERSION=LITE
# PostgreSQL + asyncpg
# Format: postgresql+asyncpg://user:password@localhost:5432/dbname
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/leadlock_db

# Google Sheet ID (из URL таблицы)
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Path to Google Service Account credentials JSON
GOOGLE_CREDENTIALS_JSON=/path/to/google-credentials.json

# Список ID администраторов (через запятую, без пробелов)
# Пример: 123456789,987654321,555555555
ADMIN_IDS=123456789,987654321

# OpenAI API Key (если используется интеграция с ChatGPT)
OPENAI_API_KEY=sk-your_openai_api_key_here_change_me

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO