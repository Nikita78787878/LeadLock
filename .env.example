# ============================================================================
# BOT CONFIGURATION / КОНФИГУРАЦИЯ БОТА
# ============================================================================

# Telegram Bot Token (получить у @BotFather)
BOT_TOKEN=your_telegram_bot_token_here_change_me

# Bot version (LITE, PRO, AI)
VERSION=LITE

# ============================================================================
# DATABASE / БАЗА ДАННЫХ
# ============================================================================

# PostgreSQL + asyncpg
# Format: postgresql+asyncpg://user:password@localhost:5432/dbname
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/leadlock_db

# ============================================================================
# GOOGLE SHEETS / GOOGLE ТАБЛИЦЫ
# ============================================================================

# Google Sheet ID (из URL таблицы)
# Пример: https://docs.google.com/spreadsheets/d/1abc2def3ghi4jkl5mno6pqr7stu8vwx/edit
# ID = 1abc2def3ghi4jkl5mno6pqr7stu8vwx
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Path to Google Service Account credentials JSON
# Скачать из Google Cloud Console
GOOGLE_CREDENTIALS_JSON=/path/to/google-credentials.json

# ============================================================================
# ADMIN CONFIGURATION / КОНФИГУРАЦИЯ АДМИНИСТРАТОРА
# ============================================================================

# Список ID администраторов (через запятую, без пробелов)
# Пример: 123456789,987654321,555555555
ADMIN_IDS=123456789,987654321

# ============================================================================
# OPENAI CONFIGURATION / КОНФИГУРАЦИЯ OPENAI
# ============================================================================

# OpenAI API Key (если используется интеграция с ChatGPT)
OPENAI_API_KEY=sk-your_openai_api_key_here_change_me

# ============================================================================
# LOGGING / ЛОГИРОВАНИЕ (опционально)
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================================================
# ПРИМЕЧАНИЯ / NOTES
# ============================================================================

# 1. BOT_TOKEN: Получить у @BotFather в Telegram
#    Bot Father команда: /newbot
#
# 2. DATABASE_URL: Убедитесь, что PostgreSQL запущен
#    docker run -d --name postgres \
#      -e POSTGRES_PASSWORD=postgres \
#      -e POSTGRES_DB=leadlock_db \
#      -p 5432:5432 \
#      postgres:latest
#
# 3. GOOGLE_CREDENTIALS_JSON:
#    - Создайте проект в Google Cloud Console
#    - Включите Google Sheets API
#    - Создайте Service Account
#    - Скачайте JSON ключ
#    - Поделитесь таблицей с email сервис-аккаунта
#
# 4. ADMIN_IDS: Ваш ID можно узнать у @userinfobot
#
# ============================================================================
